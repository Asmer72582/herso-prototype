{
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://herso-prototype-backend.vercel.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://herso-prototype-backend.vercel.app/uploads/$1"
    },
    {
      "source": "/((?!assets/|favicon.ico|.*\\.js|.*\\.css|.*\\.png|.*\\.jpg|.*\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}