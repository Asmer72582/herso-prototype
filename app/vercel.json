{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://herso-prototype-backend.vercel.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://herso-prototype-backend.vercel.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "experimentalServices": {
        "frontend": {
          "routePrefix": "/",
          "framework": "vite"
        },
        "backend": {
          "entrypoint": "backend",
          "routePrefix": "/_/backend"
        }
      }
    }
  ]
}